$hostpools = Get-AzWvdHostPool

foreach ($vmName in $pagefileVMsNames) {

  $vm = Get-AzVM -Name $vmName
  $rgName = $vm.ResourceGroupName
  Write-Host "Processing VM: $vmName in RG: $rgName"

  $hasActiveSession = $false

  foreach ($hp in $hostpools) {

    $sessions = Get-AzWvdUserSession -HostPoolName $hp.Name -ResourceGroupName $hp.ResourceGroupName

    $active = $sessions | Where-Object {
      $_.SessionHostName -like "*$vmName*" -and $_.State -eq "Active"
    }

    if ($active) {
      $hasActiveSession = $true
      Write-Host "Skipping $vmName - Active session found"
      break
    }
  }

  if ($hasActiveSession) {
    continue
  }

  $script = @'
    Write-Host "Disabling Automatic Page File Management..."

    $cs = Get-CimInstance Win32_ComputerSystem
    Set-CimInstance -InputObject $cs -Property @{AutomaticManagedPagefile = $false}

    Write-Host "Removing existing Page File settings..."
    Get-CimInstance Win32_PageFileSetting | Remove-CimInstance

    Write-Host "Setting Page File to C:\pagefile.sys ..."

    Set-ItemProperty `
        -Path "HKLM:\SYSTEM\CurrentControlSet\Control\Session Manager\Memory Management" `
        -Name "PagingFiles" `
        -Value "C:\pagefile.sys 8192 8192"

    Write-Host "Done. Reboot required."
'@

  $pageFile = Invoke-AzVMRunCommand `
    -ResourceGroupName $rgName `
    -VMName $vmName `
    -CommandId 'RunPowerShellScript' `
    -ScriptString $script

  Write-Host "Restarting VM..."
  Restart-AzVM -ResourceGroupName $rgName -Name $vmName

  if ($pageFile.Value[0].Message) {
    Write-Host "RunCommand output: $($pageFile.Value[0].Message)"
  }
}

foreach ($vmName in $diskSizeUpVMsNames) {
  $hasActiveSession = $false

  foreach ($hp in $hostpools) {

    $sessions = Get-AzWvdUserSession -HostPoolName $hp.Name -ResourceGroupName $hp.ResourceGroupName

    $active = $sessions | Where-Object {
      $_.SessionHostName -like "*$vmName*" -and $_.State -eq "Active"
    }

    if ($active) {
      $hasActiveSession = $true
      Write-Host "Skipping $vmName - Active session found"
      break
    }
  }

  if ($hasActiveSession) {
    continue
  }

  $vm = Get-AzVM -Name $vmName
  $rgName = $vm.ResourceGroupName

  $vm = Get-AzVM -ResourceGroupName $rgName -Name $vmName
  $diskId = $vm.StorageProfile.OsDisk.ManagedDisk.Id
  $diskName = ($diskId -split "/")[-1]

  $disk = Get-AzDisk -ResourceGroupName $rgName -DiskName $diskName

  $currentSizeGB = $disk.DiskSizeGB
  $newSizeGB = $currentSizeGB * 2

  if ($newSizeGB -gt 1024) {
    $newSizeGB = 1024
  }
  Write-Host "vm name: $vmName"
  Write-Host "Current disk size: $currentSizeGB GB"
  Write-Host "New disk size: $newSizeGB GB"

  Stop-AzVM -ResourceGroupName $rgName -Name $vmName -Force

  $disk.DiskSizeGB = $newSizeGB
  Update-AzDisk -ResourceGroupName $rgName -Disk $disk -DiskName $diskName

  Start-AzVM -ResourceGroupName $rgName -Name $vmName

  $script = @'
        $drive = $env:SystemDrive.TrimEnd(":")

        Write-Host "Expanding drive $drive..."

        $partition = Get-Partition -DriveLetter $drive
        $disk = Get-Disk -Number $partition.DiskNumber

        $size = Get-PartitionSupportedSize `
            -DiskNumber $disk.Number `
            -PartitionNumber $partition.PartitionNumber

        Resize-Partition `
            -DiskNumber $disk.Number `
            -PartitionNumber $partition.PartitionNumber `
            -Size $size.SizeMax

        Write-Host "Done expanding C:"

        Get-Volume -DriveLetter $drive
'@

  Invoke-AzVMRunCommand `
    -ResourceGroupName $rgName `
    -VMName $vmName `
    -CommandId 'RunPowerShellScript' `
    -ScriptString $script
  Restart-AzVM -ResourceGroupName $rgName -Name $vmName

}
