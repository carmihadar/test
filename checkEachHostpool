function Wait-ForVm {
  param(
    [string]$rg,
    [string]$vmName,
    [string]$desiredState,
    [int]$maxWaitSeconds = 900
  )

  $elapsed = 0

  while ($elapsed -lt $maxWaitSeconds) {

    Start-Sleep -Seconds 15
    $elapsed += 15

    $vm = Get-AzVM -ResourceGroupName $rg -Name $vmName -Status
    $powerState = ($vm.Statuses | Where-Object Code -like "PowerState/*").Code

    Write-Host "Current state: $powerState (elapsed: ${elapsed}s)"

    if ($powerState -eq $desiredState) {
      Write-Host "VM reached desired state" -ForegroundColor Cyan
      return $true
    }
  }

  Write-Warning "Timeout waiting for VM $vmName"
  return $false
}

$hostPools = @(
